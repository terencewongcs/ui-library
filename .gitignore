# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
storybook-static/

# ── Environment / secrets ────────────────────────────────────────────────────
# Never commit real env files; commit only the example template
.env
.env.*
!.env.example

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test & coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Vite ─────────────────────────────────────────────────────────────────────
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── ESLint / Prettier cache ──────────────────────────────────────────────────
.eslintcache
.stylelintcache
.prettiercache

# ── OS & editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── npm pack output ──────────────────────────────────────────────────────────
*.tgz

# ── Chromatic / Storybook ────────────────────────────────────────────────────
.chromatic/

# ── GitHub Actions local runners ─────────────────────────────────────────────
.act/
